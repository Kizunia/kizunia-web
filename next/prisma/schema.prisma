// Kizunia Web — Prisma Schema
//
// Architecture: PostgreSQL + Prisma ORM
// Auth: Better Auth (User, Session, Account, Verification)
//
// Conventions:
// - Better Auth tables must remain compatible — do not rename their fields.
// - Badge is generic — not limited to verification.
// - HackathonStatus contains lifecycle values only. Moderation belongs to a future Proposal model.
// - Major entities support soft delete via deletedAt.
// - Audit fields (createdById, updatedById) use SetNull so history survives user deletion.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums — User
// =============================================================================

enum UserVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

// =============================================================================
// Enums — Hackathon
// =============================================================================
enum SuggestionStatus {
  DRAFT
  UNDER_REVIEW
  CHANGES_REQUESTED
  APPROVED
  REJECTED
  WITHDRAWN
}

enum HackathonMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum HackathonVisibility {
  PUBLIC
  UNLISTED
  ARCHIVED
}

// Lifecycle-only status. Moderation workflow (draft, submitted, pending review,
// approved) belongs to a future Proposal model — not the Hackathon itself.
enum HackathonStatus {
  UPCOMING
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  ONGOING
  COMPLETED
  CANCELLED
}

// Hackathons support multiple member roles beyond simple maintainers.
enum HackathonMemberRole {
  OWNER
  ORGANIZER
  MAINTAINER
}

// =============================================================================
// Enums — Project
// =============================================================================

enum ProjectVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
}

enum ProjectRole {
  OWNER
  MAINTAINER
  CONTRIBUTOR
}

enum AssetProvider {
  CLOUDINARY
}

enum LinkType {
  WEBSITE
  REGISTRATION
  GITHUB
  GITLAB
  DEMO
  DOCUMENTATION
  FIGMA
  DEVPOST
  DEVFOLIO
  UNSTOP
  LINKEDIN
  TWITTER
  INSTAGRAM
  DISCORD
  YOUTUBE
  PORTFOLIO
  OTHER
}

// =============================================================================
// Better Auth Models — DO NOT MODIFY unless absolutely necessary
// =============================================================================

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String?
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  sessions      Session[]
  accounts      Account[]

  username        String?
  displayUsername String?

  // --- Kizunia Custom Fields ---

  // Profile
  headline       String?
  bio            String?
  college        String?
  degree         String?
  graduationYear Int?
  location       String?
  avatarAssetId  String?
  avatarAsset    Asset?  @relation("userAvatar", fields: [avatarAssetId], references: [id], onDelete: SetNull)

  coverAssetId String?
  coverAsset   Asset?  @relation("userCover", fields: [coverAssetId], references: [id], onDelete: SetNull)

  // System
  visibility UserVisibility @default(PUBLIC)
  status     UserStatus     @default(ACTIVE)

  // Relationships
  links                         Link[]
  technologies                  UserTechnology[]
  interests                     UserCategory[]
  notificationPref              NotificationPreference?
  badges                        UserBadge[]
  hackathonMembers              HackathonMember[]
  hackathonBookmarks            HackathonBookmark[]
  // ---------------------------------------------------------------------------
  // Hackathon Suggestions
  // ---------------------------------------------------------------------------
  hackathonSuggestionsSubmitted HackathonSuggestion[]   @relation("hackathonSuggestionSubmittedBy")
  hackathonSuggestionsReviewed  HackathonSuggestion[]   @relation("hackathonSuggestionReviewedBy")
  projectMembers                ProjectMember[]

  // Audit — entities created or last updated by this user
  hackathonsCreated Hackathon[] @relation("hackathonCreatedBy")
  hackathonsUpdated Hackathon[] @relation("hackathonUpdatedBy")

  projectsCreated Project[] @relation("projectCreatedBy")
  projectsUpdated Project[] @relation("projectUpdatedBy")

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// =============================================================================
// Shared Models — Link, Asset, Technology, Category, Badge
// =============================================================================

// External links (GitHub, LinkedIn, Portfolio, etc.)
// Uses optional foreign keys instead of polymorphic relations for Prisma compatibility.
model Link {
  id    String   @id @default(cuid())
  url   String
  title String
  type  LinkType
  order Int      @default(0)

  userId      String?
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hackathonId String?
  hackathon   Hackathon? @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  hackathonSuggestion   HackathonSuggestion? @relation(fields: [hackathonSuggestionId], references: [id])
  hackathonSuggestionId String?

  @@index([userId])
  @@index([hackathonId])
  @@index([projectId])
  @@index([hackathonSuggestionId])
  @@map("link")
}

// Identity Asset (avatars, banners, logos). Stored via Cloudinary.
// Content Asset (screenshots, diagrams) lives in documentation or external links.
model Asset {
  id String @id @default(cuid())

  provider AssetProvider

  publicId String @unique

  secureUrl String

  format String?

  mimeType String?

  width Int?

  height Int?

  bytes            Int?
  checksum         String?
  originalFilename String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // User
  userAvatar User[] @relation("userAvatar")
  userCover  User[] @relation("userCover")

  // Hackathon
  hackathonLogo   Hackathon[] @relation("hackathonLogo")
  hackathonBanner Hackathon[] @relation("hackathonBanner")
  hackathonCover  Hackathon[] @relation("hackathonCover")

  // Suggestion
  suggestionLogo   HackathonSuggestion[] @relation("suggestionLogo")
  suggestionBanner HackathonSuggestion[] @relation("suggestionBanner")
  suggestionCover  HackathonSuggestion[] @relation("suggestionCover")

  // Project
  projectLogo  Project[] @relation("projectLogo")
  projectCover Project[] @relation("projectCover")

  @@map("asset")
}

// Global pool of technologies/skills. Shared across Users, Projects, Hackathons.
model Technology {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  iconUrl     String?
  description String?

  users                           UserTechnology[]
  hackathons                      HackathonTechnology[]
  projects                        ProjectTechnology[]
  hackathonSuggestionTechnologies HackathonSuggestionTechnology[]

  @@map("technology")
}

// Global pool of categories/interests. Shared across Users, Hackathons, Projects.
model Category {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  users                         UserCategory[]
  hackathons                    HackathonCategory[]
  projects                      ProjectCategory[]
  hackathonSuggestionCategories HackathonSuggestionCategory[]

  @@map("category")
}

// Generic badge system. Not limited to verification — supports user badges,
// project badges, and future entity badges (teams, hackathons).
model Badge {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  iconUrl     String?

  users    UserBadge[]
  projects ProjectBadge[]

  @@map("badge")
}

// =============================================================================
// User Domain — Join Tables
// =============================================================================

model UserTechnology {
  userId       String
  technologyId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  technology   Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([userId, technologyId])
  @@map("user_technology")
}

model UserCategory {
  userId     String
  categoryId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@map("user_category")
}

model UserBadge {
  userId   String
  badgeId  String
  issuedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
  @@map("user_badge")
}

model NotificationPreference {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailNotifications Boolean  @default(true)
  pushNotifications  Boolean  @default(false)
  preferences        Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("notification_preference")
}

// =============================================================================
// Hackathon Domain
// =============================================================================

model Hackathon {
  id               String @id @default(cuid())
  title            String
  slug             String @unique
  shortDescription String

  organizer            String
  mode                 HackathonMode @default(ONLINE)
  location             String?
  registrationLink     String?
  website              String?
  startDate            DateTime?
  endDate              DateTime?
  registrationDeadline DateTime?
  minTeamSize          Int?
  maxTeamSize          Int?
  prizePool            String?
  logoAssetId          String?
  logoAsset            Asset?        @relation("hackathonLogo", fields: [logoAssetId], references: [id], onDelete: SetNull)

  bannerAssetId String?
  bannerAsset   Asset?  @relation("hackathonBanner", fields: [bannerAssetId], references: [id], onDelete: SetNull)

  coverAssetId String?
  coverAsset   Asset?  @relation("hackathonCover", fields: [coverAssetId], references: [id], onDelete: SetNull)

  documentation String? @db.Text

  visibility HackathonVisibility @default(UNLISTED)
  // Lifecycle-only. Moderation status belongs to a future Proposal model.
  status     HackathonStatus     @default(UPCOMING)

  // Audit — tracks who created and last updated this hackathon.
  // Uses SetNull so audit history survives user deletion.
  createdById String?
  createdBy   User?   @relation("hackathonCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?   @relation("hackathonUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Soft delete — rows are never permanently removed from major entities.
  deletedAt DateTime?

  categories   HackathonCategory[]
  technologies HackathonTechnology[]
  members      HackathonMember[]
  bookmarks    HackathonBookmark[]
  projects     HackathonProject[]

  links Link[]
  // ---------------------------------------------------------------------------
  // Suggestions
  // ---------------------------------------------------------------------------

  suggestions HackathonSuggestion[] @relation("hackathonSuggestionTarget")

  @@index([status])
  @@index([visibility])
  @@index([deletedAt])
  @@index([startDate])
  @@index([registrationDeadline])
  @@index([createdById])
  @@index([updatedById])
  @@map("hackathon")
}

model HackathonSuggestion {
  id String @id @default(cuid())

  // ===========================================================================
  // Workflow
  // ===========================================================================

  status SuggestionStatus @default(DRAFT)

  submittedAt DateTime?
  reviewedAt  DateTime?

  reviewNotes     String? @db.Text
  rejectionReason String? @db.Text

  // ===========================================================================
  // Relationships
  // ===========================================================================

  // NULL => New Hackathon
  // NOT NULL => Edit Existing Hackathon
  hackathonId String?
  hackathon   Hackathon? @relation("hackathonSuggestionTarget", fields: [hackathonId], references: [id], onDelete: Cascade)

  submittedById String
  submittedBy   User   @relation("hackathonSuggestionSubmittedBy", fields: [submittedById], references: [id], onDelete: Cascade)

  reviewedById String?
  reviewedBy   User?   @relation("hackathonSuggestionReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  // ===========================================================================
  // Contributor Editable Fields
  // ===========================================================================

  title String

  shortDescription String

  organizer String

  mode HackathonMode @default(ONLINE)

  location String?

  registrationLink String?

  website String?

  startDate DateTime?

  endDate DateTime?

  registrationDeadline DateTime?

  minTeamSize Int?

  maxTeamSize Int?

  prizePool String?

  documentation String? @db.Text

  // ===========================================================================
  // Audit
  // ===========================================================================

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // ===========================================================================
  // Relations
  // ===========================================================================

  categories   HackathonSuggestionCategory[]
  technologies HackathonSuggestionTechnology[]

  links       Link[]
  logoAssetId String?
  logoAsset   Asset?  @relation("suggestionLogo", fields: [logoAssetId], references: [id], onDelete: SetNull)

  bannerAssetId String?
  bannerAsset   Asset?  @relation("suggestionBanner", fields: [bannerAssetId], references: [id], onDelete: SetNull)

  coverAssetId String?
  coverAsset   Asset?  @relation("suggestionCover", fields: [coverAssetId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([submittedById])
  @@index([reviewedById])
  @@index([hackathonId])
  @@index([createdAt])
  @@map("hackathon_suggestion")
}

// Hackathon members with role-based access. Replaces the old HackathonMaintainer
// model to support multiple roles (owner, organizer, maintainer).
model HackathonMember {
  hackathonId String
  userId      String
  role        HackathonMemberRole @default(MAINTAINER)
  assignedAt  DateTime            @default(now())
  hackathon   Hackathon           @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([hackathonId, userId])
  @@map("hackathon_member")
}

model HackathonCategory {
  hackathonId String
  categoryId  String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([hackathonId, categoryId])
  @@map("hackathon_category")
}

model HackathonTechnology {
  hackathonId  String
  technologyId String
  hackathon    Hackathon  @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  technology   Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([hackathonId, technologyId])
  @@map("hackathon_technology")
}

model HackathonBookmark {
  hackathonId String
  userId      String
  createdAt   DateTime  @default(now())
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([hackathonId, userId])
  @@map("hackathon_bookmark")
}

model HackathonSuggestionCategory {
  suggestionId String
  categoryId   String

  suggestion HackathonSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  category   Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([suggestionId, categoryId])
  @@map("hackathon_suggestion_category")
}

model HackathonSuggestionTechnology {
  suggestionId String
  technologyId String

  suggestion HackathonSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  technology Technology          @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([suggestionId, technologyId])
  @@map("hackathon_suggestion_technology")
}

// =============================================================================
// Project Domain
// =============================================================================

model Project {
  id               String @id @default(cuid())
  title            String
  slug             String @unique
  shortDescription String

  documentation String? @db.Text

  visibility ProjectVisibility @default(PUBLIC)
  status     ProjectStatus     @default(DRAFT)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  members      ProjectMember[]
  categories   ProjectCategory[]
  technologies ProjectTechnology[]
  badges       ProjectBadge[]
  hackathons   HackathonProject[]

  links       Link[]
  logoAssetId String?
  logoAsset   Asset?  @relation("projectLogo", fields: [logoAssetId], references: [id], onDelete: SetNull)

  coverAssetId String?
  coverAsset   Asset?  @relation("projectCover", fields: [coverAssetId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("projectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   User?   @relation("projectUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  deletedAt DateTime?

  @@map("project")
}

model ProjectMember {
  projectId String
  userId    String
  role      ProjectRole @default(CONTRIBUTOR)
  joinedAt  DateTime    @default(now())
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_member")
}

model ProjectCategory {
  projectId  String
  categoryId String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([projectId, categoryId])
  @@map("project_category")
}

model ProjectTechnology {
  projectId    String
  technologyId String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  technology   Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([projectId, technologyId])
  @@map("project_technology")
}

model ProjectBadge {
  projectId String
  badgeId   String
  issuedAt  DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([projectId, badgeId])
  @@map("project_badge")
}

// Many-to-many: a project can be submitted to multiple hackathons.
model HackathonProject {
  hackathonId String
  projectId   String
  submittedAt DateTime  @default(now())
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([hackathonId, projectId])
  @@map("hackathon_project")
}
